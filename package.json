{
  "name": "marchol",
  "version": "17.0.8",
  "description": "Marchol browser installer project",
  "license": "MIT",
  "author": "Michał",
  "type": "module",
  "main": "./src/main.js",
  "scripts": {
    "start": "nodemon --exec electron ."
  },
  "build": {
    "appId": "com.node.marchol",
    "productName": "Marchol",
    "directories": {
      "output": "pack"
    },
    "files": [
      "src/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "./assets/icon.ico",
      "artifactName": "installer.exe"
    },
    "asar": false
  },
  "devDependencies": {
    "electron": "^35.1.5"
  },
  "dependencies": {
    "@types/electron": "^1.4.38",
    "@types/express": "^5.0.1",
    "@types/ws": "^8.18.1",
    "express": "^5.1.0",
    "npm": "^11.3.0",
    "typescript": "^5.8.3",
    "ws": "^8.18.1"
  }
}