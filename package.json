{
  "name": "marchol",
  "version": "17.0.8",
  "description": "Marchol browser installer project",
  "license": "MIT",
  "author": "Michał",
  "type": "module",
  "main": "./src/main.js",
  "scripts": {
    "start": "start start.bat",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.node.marchol",
    "productName": "Marchol",
    "directories": {
      "output": "pack"
    },
    "files": [
      "dist/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true
    },
    "win": {
      "target": ["nsis"],
      "icon": "./assets/icon.ico",
      "artifactName": "installer.exe"
    },
    "asar": false
  },
  "devDependencies": {
	"electron": "^35.1.5"
  },
  "dependencies": {
    "express": "^5.1.0",
    "@types/electron": "^1.4.38",
    "@types/express": "^5.0.1",
    "@types/ws": "^8.18.1",
    "ws": "^8.18.1",
    "typescript": "^5.8.3"
  }
}